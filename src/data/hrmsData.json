  "documentTemplates": [
    {
      "id": 1,
      "title": "Offer Letter",
      "category": "hiring",
      "description": "Formal job offer with role, CTC, and joining details.",
      "updatedAt": "2026-04-15",
      "body": "GAMYAM TECHNOLOGIES PVT. LTD.\nHyderabad, Telangana\n\nDate: {{letter_date}}\n\nDear {{employee_name}},\n\nWe are pleased to offer you the position of {{role}} in our {{department}} department at Gamyam Technologies.\n\nEmployee ID (on joining): {{employee_id}}\nWork location: {{work_location}}\nDate of joining: {{join_date}}\nAnnual CTC: {{annual_ctc}}\nReporting to: {{reporting_manager}}\n\nThis offer is subject to satisfactory background verification and submission of required documents on or before your joining date.\n\nWe look forward to welcoming you to the team.\n\nSincerely,\n{{hr_signatory}}\nHuman Resources\nGamyam Technologies"
    },
    {
      "id": 2,
      "title": "Appointment Letter",
      "category": "hiring",
      "description": "Confirms employment terms after the candidate accepts the offer.",
      "updatedAt": "2026-04-10",
      "body": "GAMYAM TECHNOLOGIES PVT. LTD.\n\nDate: {{letter_date}}\n\nTo,\n{{employee_name}}\n{{employee_email}}\n\nSubject: Appointment Letter – {{role}}\n\nDear {{employee_name}},\n\nWith reference to your acceptance of our offer dated {{letter_date}}, you are hereby appointed as {{role}} ({{department}}) with effect from {{join_date}}.\n\nYour employment will be governed by company policies, including leave, attendance, and code of conduct, as amended from time to time.\n\nWork hours: 9:00 AM – 6:00 PM (Monday–Friday)\nWork location: {{work_location}}\n\nPlease sign and return a copy of this letter as token of your acceptance.\n\nFor Gamyam Technologies,\n{{hr_signatory}}\nHR Manager"
    },
    {
      "id": 3,
      "title": "Employment Contract",
      "category": "employment",
      "description": "Standard full-time employment agreement template.",
      "updatedAt": "2026-03-20",
      "body": "EMPLOYMENT AGREEMENT\n\nThis Agreement is entered on {{letter_date}} between Gamyam Technologies Pvt. Ltd. (\"Company\") and {{employee_name}} (\"Employee\"), ID {{employee_id}}.\n\n1. Position: {{role}}, {{department}} department.\n2. Commencement: {{join_date}}.\n3. Compensation: Annual CTC {{annual_ctc}} as per company payroll policy.\n4. Confidentiality: Employee shall not disclose proprietary information.\n5. Termination: Either party may terminate with notice as per applicable labour laws and company policy.\n\nEmployee signature: _________________    Date: _________\n\nFor Company: {{hr_signatory}}"
    },
    {
      "id": 4,
      "title": "NDA & Confidentiality",
      "category": "compliance",
      "description": "Non-disclosure agreement for employees and contractors.",
      "updatedAt": "2026-02-01",
      "body": "NON-DISCLOSURE AGREEMENT\n\nDate: {{letter_date}}\n\nBetween Gamyam Technologies and {{employee_name}} ({{employee_email}}).\n\nThe Employee acknowledges access to confidential information including product roadmaps, client data, and HR records. The Employee agrees not to disclose such information during employment and for two (2) years thereafter.\n\nGoverning law: Laws of India. Jurisdiction: Hyderabad.\n\nSigned:\n{{employee_name}} _________________\n{{hr_signatory}} (HR) _________________"
    },
    {
      "id": 5,
      "title": "Experience Certificate",
      "category": "exit",
      "description": "Issued when an employee completes their tenure.",
      "updatedAt": "2026-01-18",
      "body": "TO WHOMSOEVER IT MAY CONCERN\n\nDate: {{letter_date}}\n\nThis is to certify that {{employee_name}} (Employee ID: {{employee_id}}) was employed with Gamyam Technologies Pvt. Ltd. as {{role}} in the {{department}} department from {{join_date}} to {{relieving_date}}.\n\nDuring this period, we found {{employee_name}} to be sincere, diligent, and professional in conduct.\n\nWe wish {{employee_name}} success in future endeavours.\n\nFor Gamyam Technologies,\n{{hr_signatory}}\nAuthorized Signatory"
    },
    {
      "id": 6,
      "title": "Relieving Letter",
      "category": "exit",
      "description": "Confirms last working day and clearance of dues.",
      "updatedAt": "2026-01-18",
      "body": "GAMYAM TECHNOLOGIES PVT. LTD.\n\nDate: {{letter_date}}\n\nDear {{employee_name}},\n\nThis is to confirm that you were relieved from your services as {{role}} ({{department}}) with effect from {{relieving_date}}, following acceptance of your resignation and completion of exit formalities.\n\nYour full and final settlement will be processed as per company policy. Please return all company assets if not already submitted.\n\nWe thank you for your contributions.\n\nSincerely,\n{{hr_signatory}}\nHuman Resources"
    },
